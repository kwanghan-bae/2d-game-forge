{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": false,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/game/*": ["../../games/inflation-rpg/src/game/*"],
      "@/components/ui/*": ["../../games/inflation-rpg/src/components/ui/*"],
      "@/lib/*": ["../../games/inflation-rpg/src/lib/*", "./src/lib/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "out"]
}
